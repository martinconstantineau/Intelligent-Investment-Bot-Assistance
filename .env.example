# Supabase client config
# Use the Project URL and Publishable (anon) key from Supabase Project Settings > API / Connect.
# Set ONE of the two key variables below — both names are accepted:
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY  (matches the Supabase dashboard label)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY         (matches the official Supabase Next.js template)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Future external integrations. Not required for the first Supabase MVP.
OPENAI_API_KEY=
FMP_API_KEY=
FINNHUB_API_KEY=
COINGECKO_API_KEY=
